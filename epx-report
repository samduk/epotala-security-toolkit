#!/usr/bin/env python3
"""
epx-report
==========

Takes an epxtool scan or forensic JSON and turns it into a readable report.

Examples:
  ./epx-report reports/site.json                       (Markdown to screen)
  ./epx-report reports/site.json -f html -o site.html  (HTML to a file)
"""

import argparse
import json
import os
import sys

# Make sure Python can find the "epxtool" package that lives next to this file.
HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, HERE)

from epxtool import __version__, SHORT_NAME
from epxtool.io_utils import sha256_text, verify_artifact, write_artifact
from epxtool.forensics_report import (
    build_forensics_html,
    build_forensics_markdown,
)
from epxtool.forensics_schema import validate_forensics_result
from epxtool.report import build_markdown, build_html
from epxtool.schema import validate_result


def main():
    parser = argparse.ArgumentParser(
        prog="epx-report",
        description=(
            "EPX Report: turn an EPX JSON artifact into a Markdown or HTML report."
        ),
    )
    parser.add_argument("input", nargs="?", default="-",
                        help="The epxtool JSON file (default: read from screen)")
    parser.add_argument("-f", "--format", choices=("md", "html"), default="md",
                        help="Report format: md or html (default: md)")
    parser.add_argument("-o", "--output",
                        help="Where to save the report (default: print to screen)")
    parser.add_argument("--client-name",
                        help="Client name shown in this report")
    parser.add_argument("--reviewed-by",
                        help="Named analyst who reviewed the findings")
    parser.add_argument("--report-id",
                        help="Report identifier (default: <scan-id>-R1)")
    parser.add_argument("--ignore-integrity", action="store_true",
                        help="Continue if an existing SHA-256 sidecar does not match")
    parser.add_argument("--version", action="version",
                        version=SHORT_NAME + " " + __version__)
    args = parser.parse_args()

    # 1) Read the JSON, either from a file or from standard input.
    if args.input == "-":
        raw_text = sys.stdin.read()
        source_digest = sha256_text(raw_text)
        integrity_status = "not verified (stdin)"
    else:
        try:
            with open(args.input, "r", encoding="utf-8") as handle:
                raw_text = handle.read()
            source_digest, verified = verify_artifact(args.input)
        except OSError as error:
            sys.stderr.write("error: could not read JSON: " + str(error) + "\n")
            return 1
        if verified is False and not args.ignore_integrity:
            sys.stderr.write(
                "error: input JSON does not match " + args.input +
                ".sha256 (use --ignore-integrity only after investigation)\n"
            )
            return 1
        if verified is True:
            integrity_status = "verified"
        elif verified is False:
            integrity_status = "mismatch ignored"
        else:
            integrity_status = "no sidecar"

    # 2) Turn the text into a Python dictionary.
    try:
        result = json.loads(raw_text)
    except ValueError as error:
        sys.stderr.write("error: that file is not valid JSON (" + str(error) + ")\n")
        return 1

    # 3) Check the result shape, then build the chosen report format.
    try:
        is_forensics = result.get("artifact_type") == "forensics"
        if is_forensics:
            validate_forensics_result(result)
        else:
            validate_result(result)
        result["_report_context"] = {
            "client_name": args.client_name or "",
            "reviewed_by": args.reviewed_by or "",
            "report_id": args.report_id or "",
            "source_sha256": source_digest,
            "integrity_status": integrity_status,
        }
        if args.format == "html" and is_forensics:
            report_text = build_forensics_html(result)
        elif args.format == "html":
            report_text = build_html(result)
        elif is_forensics:
            report_text = build_forensics_markdown(result)
        else:
            report_text = build_markdown(result)
    except ValueError as error:
        sys.stderr.write("error: invalid epxtool data (" + str(error) + ")\n")
        return 1

    # 4) Save it or print it.
    if args.output:
        try:
            digest = write_artifact(args.output, report_text, mode=0o600)
        except OSError as error:
            sys.stderr.write("error: could not save report: " + str(error) + "\n")
            return 1
        sys.stderr.write("[+] Saved " + args.format + " report to " + args.output + "\n")
        sys.stderr.write("[+] SHA-256: " + digest + "\n")
    else:
        sys.stdout.write(report_text)

    return 0


if __name__ == "__main__":
    sys.exit(main())
